# Copy this file to .env and fill in your values before running docker-compose.

# MinIO object storage credentials
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me

# JWT signing secret — use a long random string in production
JWT_SECRET_KEY=change-me

# OE Dashboard admin credentials
OE_ADMIN_USER=admin
OE_ADMIN_PASSWORD=change-me

# Demo user passwords
ML_USER_PASSWORD=change-me
CUSTOMER1_PASSWORD=change-me
ADMIN_PASSWORD=change-me
